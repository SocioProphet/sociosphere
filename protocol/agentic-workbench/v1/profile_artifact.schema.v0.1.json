{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sourceos.local/schemas/agentic-workbench/v1/profile_artifact.schema.v0.1.json",
  "title": "ProfileArtifact",
  "description": "First-class profiling output object for workbench execution surfaces. ProfileArtifact MUST reference exactly one WorkflowRun and be admissible into ExecutionRecord evidence sets.",
  "type": "object",
  "required": [
    "profileArtifactId",
    "runId",
    "toolchain",
    "collectionMode",
    "createdAt",
    "outputRefs"
  ],
  "properties": {
    "profileArtifactId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "executionRecordRef": {
      "type": "string"
    },
    "phase": {
      "type": "string",
      "enum": [
        "validation",
        "placement",
        "grant",
        "dispatch",
        "result",
        "replay"
      ]
    },
    "toolchain": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "adapterRef": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "collectionMode": {
      "type": "string",
      "enum": [
        "sampling",
        "tracing",
        "counters",
        "timeline",
        "mixed"
      ]
    },
    "samplePeriodMs": {
      "type": "integer",
      "minimum": 0
    },
    "inputDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "outputRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://sourceos.local/schemas/agentic-workbench/v1/artifact_ref.schema.v0.1.json"
      }
    },
    "summary": {
      "type": "object"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
