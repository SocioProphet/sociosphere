{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sourceos.local/schemas/agentic-workbench/v1/launch_dispatch_record.schema.v0.1.json",
  "title": "LaunchDispatchRecord",
  "description": "Scheduler-facing dispatch projection for a LaunchConfig. This object captures dispatch posture and identifiers without replacing ExecutionRecord or receipt canon.",
  "type": "object",
  "required": [
    "dispatchId",
    "launchId",
    "runId",
    "schedulerKind",
    "dispatchStatus",
    "createdAt"
  ],
  "properties": {
    "dispatchId": {
      "type": "string",
      "minLength": 1
    },
    "launchId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "launchConfigRef": {
      "type": "string"
    },
    "schedulerKind": {
      "type": "string",
      "enum": [
        "local",
        "slurm",
        "tekton",
        "unknown"
      ]
    },
    "dispatchStatus": {
      "type": "string",
      "enum": [
        "prepared",
        "submitted",
        "accepted",
        "rejected",
        "running",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "queueRef": {
      "type": "string"
    },
    "schedulerJobId": {
      "type": "string"
    },
    "placement": {
      "type": "object",
      "properties": {
        "clusterRef": {
          "type": "string"
        },
        "nodeRef": {
          "type": "string"
        },
        "partition": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "resourceSnapshot": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        },
        "gpu": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
