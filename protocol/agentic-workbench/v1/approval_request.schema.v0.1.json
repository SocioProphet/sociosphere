{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sourceos.local/schemas/agentic-workbench/v1/approval_request.schema.v0.1.json",
  "title": "ApprovalRequest",
  "type": "object",
  "required": [
    "approvalId",
    "runId",
    "stepId",
    "reason",
    "dangerClass",
    "requiredQuorum",
    "validators",
    "payloadHash",
    "expiresAt",
    "decisionStatus"
  ],
  "properties": {
    "approvalId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "stepId": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "dangerClass": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH"
      ]
    },
    "requiredQuorum": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "payloadHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "requestedBy": {
      "type": "string"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    },
    "decisionStatus": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "expired"
      ]
    },
    "quorumProofRef": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
