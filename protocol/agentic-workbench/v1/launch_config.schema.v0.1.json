{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sourceos.local/schemas/agentic-workbench/v1/launch_config.schema.v0.1.json",
  "title": "LaunchConfig",
  "description": "Workbench-side execution request refinement object. LaunchConfig MUST reference exactly one WorkflowRun and one ExecutionEnvelope and MUST NOT redefine receipt canon.",
  "type": "object",
  "required": [
    "launchId",
    "runId",
    "executionEnvelopeRef",
    "launchMode",
    "createdAt"
  ],
  "properties": {
    "launchId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "executionEnvelopeRef": {
      "type": "string",
      "minLength": 1
    },
    "runtimeProfileRef": {
      "type": "string"
    },
    "launchMode": {
      "type": "string",
      "enum": [
        "local",
        "scheduler",
        "fog",
        "cluster"
      ]
    },
    "schedulerKind": {
      "type": "string",
      "enum": [
        "local",
        "slurm",
        "tekton",
        "unknown"
      ]
    },
    "placementHints": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "resourceHints": {
      "type": "object",
      "properties": {
        "cpu": {
          "type": "string"
        },
        "memory": {
          "type": "string"
        },
        "gpu": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "env": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "string"
          },
          "valueRef": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "oneOf": [
          {
            "required": [
              "value"
            ]
          },
          {
            "required": [
              "valueRef"
            ]
          }
        ]
      }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "labels": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
