{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://socioprophet.local/sociosphere/schema/decision-planes.schema.json",
  "title": "Strategic Decision Planes Registry",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "updated_at", "status", "source_of_truth", "planes"],
  "properties": {
    "version": { "type": "string", "minLength": 1 },
    "updated_at": { "type": ["string", "number"] },
    "status": { "type": "string", "minLength": 1 },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": true,
      "required": ["narrative_repo", "narrative_path", "registry_repo", "registry_path"],
      "properties": {
        "narrative_repo": { "type": "string", "minLength": 1 },
        "narrative_path": { "type": "string", "minLength": 1 },
        "registry_repo": { "type": "string", "minLength": 1 },
        "registry_path": { "type": "string", "minLength": 1 }
      }
    },
    "planes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "name",
          "thesis",
          "primary_anchor",
          "owner_role",
          "maturity",
          "release_source_of_truth",
          "gates",
          "metrics",
          "risks"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^SDP-[0-9]+$"
          },
          "name": { "type": "string", "minLength": 1 },
          "thesis": { "type": "string", "minLength": 1 },
          "primary_anchor": {
            "type": "object",
            "additionalProperties": true,
            "required": ["repo", "type"],
            "properties": {
              "repo": { "type": "string", "minLength": 1 },
              "type": { "type": "string", "minLength": 1 }
            }
          },
          "supporting_anchors": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "owner_role": { "type": "string", "minLength": 1 },
          "maturity": {
            "type": "object",
            "additionalProperties": true,
            "required": ["current", "target_90d", "target_12m"],
            "properties": {
              "current": { "type": "string", "minLength": 1 },
              "target_90d": { "type": "string", "minLength": 1 },
              "target_12m": { "type": "string", "minLength": 1 }
            }
          },
          "release_source_of_truth": {
            "type": "object",
            "additionalProperties": true,
            "required": ["repo", "path"],
            "properties": {
              "repo": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 }
            }
          },
          "gates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["id", "description"],
              "properties": {
                "id": { "type": "string", "minLength": 1 },
                "description": { "type": "string", "minLength": 1 }
              }
            }
          },
          "metrics": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "risks": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
